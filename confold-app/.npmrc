# Public registry — this is an OSS project; contributors must install without any internal infra.
# (pnpm lockfiles store integrity hashes, not registry URLs, so the lockfile stays portable.)
registry=https://registry.npmjs.org/

# NOTE: pnpm-specific settings (onlyBuiltDependencies, overrides, minimumReleaseAge) live in
# pnpm-workspace.yaml — pnpm 11 no longer reads them from .npmrc or package.json.
